@inherits LayoutComponentBase

<div class="page">
    <main>
        <AuthorizeView Roles="Manager">
            <Authorized>
                <p>Manager</p>
            </Authorized>
            <NotAuthorized>
                <div>
                    <NavMenu />
                </div>

                <article class="content main-body">
                    @Body
                </article>
            </NotAuthorized>
        </AuthorizeView>
    </main>
</div>
